<% if (dev) { %>
  <script>
    (async () => {
      try {
        const stream = (await fetch('/dev/reload')).body.getReader();
        while (!(await stream.read()).done);
      } catch {}
      // stream dropped -> server is restarting; wait until it answers, then reload
      for (;;) {
        try { await fetch('/dev/reload'); break; }
        catch { await new Promise((r) => setTimeout(r, 300)); }
      }
      location.reload();
    })();
  </script>
<% } %>
