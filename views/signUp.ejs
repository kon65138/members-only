<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
    href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap"
    rel="stylesheet"
    />
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/signUp.css">
    <title>Document</title>
</head>
<body>
    <h1 id="title"><a href="/">Club House</a></h1>
    <div class="formWrapper">
        <h2>Sign Up</h2>
        <form action="signUp" id="signUpForm" method="post">
            <div class="inptWrapper">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" name="first_name" required>
            </div>
            <div class="inptWrapper">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" name="last_name">
            </div>
            <div class="inptWrapper">
                <label for="username">Username or Email</label>
                <input type="text" id="username" name="username" required>
            </div>
            <div class="inptWrapper">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <div class="inptWrapper">
                <label for="passwordConfirmation">Password Confirmation</label>
                <input type="password" id="passwordConfirmation" name="password_confirmation" required>
            </div>
            <span class="errors"><ul><% if (errors) {errors.forEach( error => { %>
                                        <li><%= error.msg %></li>
                                    <% })} %>
                                </ul></span>
            <button type="submit">Sign Up</button>
        </form>
    </div>
    <%- include('partials/dev-reload') %>
</body>
</html>